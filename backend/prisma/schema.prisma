generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model timer_sessions {
  id         Int       @id @default(autoincrement())
  user_id    Int
  start_time DateTime  @default(now()) @db.DateTime(0)
  end_time   DateTime? @db.DateTime(0)
  duration   Int?
  note       String?   @db.VarChar(255)
  user       user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_timer_user")

  @@index([user_id], map: "fk_timer_user")
}

model todo {
  id          Int         @id @default(autoincrement())
  title       String      @db.VarChar(255)
  description String      @db.Text
  created_at  DateTime?   @default(now()) @db.DateTime(0)
  due_time    DateTime    @db.DateTime(0)
  status      todo_status @default(not_started)
  user_id     Int
  user        user        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "todo_ibfk_1")

  @@index([user_id], map: "user_id")
}

model user {
  id             Int              @id @default(autoincrement())
  email          String           @unique(map: "email") @db.VarChar(255)
  password       String           @db.VarChar(255)
  name           String           @db.VarChar(100)
  firstname      String           @db.VarChar(100)
  role           user_role        @default(employe)
  created_at     DateTime?        @default(now()) @db.DateTime(0)
  timer_sessions timer_sessions[]
  todo           todo[]
}

enum user_role {
  manager
  employe
}

enum todo_status {
  not_started @map("not started")
  todo
  in_progress @map("in progress")
  done
}
